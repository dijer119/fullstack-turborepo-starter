# Prisma + SQLite Configuration
# DB 파일 경로 — schema.prisma 기준 상대경로 (Prisma 관례)
DATABASE_URL="file:../data/company-map.db"

# Environment
NODE_ENV=development

# 한국은행 ECOS API (국채금리 — 퀀트 대시보드 국채시가배당률·서준식 배수에 사용)
# 미설정 시 해당 카드만 "—"로 표시되고 나머지는 정상 동작
# 발급: https://ecos.bok.or.kr → 인증키 신청
ECOS_API_KEY=
# 선택: 통계표·항목 코드 재정의 (기본값: 817Y002 / 010210000 국고채 10년)
# ECOS_TREASURY_STAT_CODE=817Y002
# ECOS_TREASURY_ITEM_CODE=010210000

# 토스증권 Open API (보유종목 조회 — /stocks/toss-holdings)
# 발급: 토스증권 WTS 설정 > Open API. 미설정 시 해당 페이지만 안내문 표시
# 선택: TOSS_ACCOUNT_SEQ 로 사용할 계좌 지정 (미설정 시 첫 계좌 자동 사용)
TOSS_API_KEY=
TOSS_API_SECRET=
# TOSS_ACCOUNT_SEQ=1
# 무한매수법 전역 킬스위치: =1 이면 LIVE 사이클이어도 모든 주문이 모의(simulated) 처리됨. 검증 후 0 또는 삭제로 해제.
INFINITE_BUY_DISABLED=1
