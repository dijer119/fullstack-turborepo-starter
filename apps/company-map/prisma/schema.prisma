generator client {
  provider      = "prisma-client-js"
  output        = "../../../node_modules/@prisma-clients/company-map"
  binaryTargets = ["native"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Industry {
  id          String   @id @default(uuid())
  name        String
  parentId    String?  @map("parent_id")
  parent      Industry?  @relation("IndustryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    Industry[] @relation("IndustryTree")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt       @map("updated_at")
  companyMappings CompanyIndustry[]

  @@index([parentId])
  @@index([name])
  @@map("industries")
}

model Company {
  id          String   @id @default(uuid())
  name        String
  ticker      String?  @unique
  market      String?
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt       @map("updated_at")
  industryMappings CompanyIndustry[]

  @@index([name])
  @@map("companies")
}

model CompanyIndustry {
  companyId  String   @map("company_id")
  industryId String   @map("industry_id")
  createdAt  DateTime @default(now()) @map("created_at")
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  industry   Industry @relation(fields: [industryId], references: [id], onDelete: Cascade)

  @@id([companyId, industryId])
  @@index([industryId])
  @@map("company_industries")
}

model StockMaster {
  code      String   @id
  name      String
  market    String?
  marcap    BigInt?
  corpCode  String?  @map("corp_code")
  // 자사주 소각 결정 공시 누적 횟수. 상세화면 "공시 갱신" 시 fetchDisclosuresForStock가 갱신.
  treasuryCancelCount Int @default(0) @map("treasury_cancel_count")
  updatedAt DateTime @updatedAt @map("updated_at")

  analysis              StockAnalysis?
  ncavResult            NcavResult?
  vipHoldings           VipHolding[]
  financialSnapshot     FinancialSnapshot?
  opIncomeHistory       OperatingIncomeHistory[]
  tags                  StockTag[]
  priceChange           PriceChange?
  memo                  StockMemo?
  override              StockOverride?
  disclosures           Disclosure[]
  links                 StockLink[]
  rating                StockRating?

  @@index([name])
  @@index([market])
  @@index([marcap])
  @@map("stock_masters")
}

model StockAnalysis {
  code              String   @id
  name              String
  currentPrice      Float?   @map("current_price")
  intrinsicValue    Float?   @map("intrinsic_value")
  safetyMargin      Float?   @map("safety_margin")
  treasuryRatio     Float?   @map("treasury_ratio")
  dividendYield     Float?   @map("dividend_yield")
  per               Float?   @map("per")
  pbr               Float?   @map("pbr")
  lastUpdated       DateTime @map("last_updated")

  master  StockMaster @relation(fields: [code], references: [code], onDelete: Cascade)

  @@index([safetyMargin])
  @@index([dividendYield])
  @@index([per])
  @@index([pbr])
  @@index([lastUpdated])
  @@map("stock_analyses")
}

model NcavResult {
  code              String   @id
  name              String
  ncav              BigInt
  marcap            BigInt
  ncavRatio         Float?   @map("ncav_ratio")
  currentAssets     BigInt   @map("current_assets")
  totalLiabilities  BigInt   @map("total_liabilities")
  totalAssets       BigInt   @map("total_assets")
  totalEquity       BigInt   @map("total_equity")
  bsnsYear          Int      @map("bsns_year")
  ncavPositive      Boolean  @map("ncav_positive")
  lastUpdated       DateTime @map("last_updated")

  master  StockMaster @relation(fields: [code], references: [code], onDelete: Cascade)

  @@index([ncavRatio])
  @@index([ncavPositive])
  @@map("ncav_results")
}

model TradeStat {
  id          Int      @id @default(autoincrement())
  category    String   @default("semiconductor")
  yearMonth   String   @map("year_month")
  hsCode      String   @map("hs_code")
  hsCodeName  String?  @map("hs_code_name")
  countryCd   String   @map("country_cd")
  countryName String   @map("country_name")
  expDlr      BigInt   @map("exp_dlr")
  impDlr      BigInt   @map("imp_dlr")
  expWgt      BigInt   @map("exp_wgt")
  impWgt      BigInt   @map("imp_wgt")
  balPayments BigInt   @map("bal_payments")
  fetchedAt   DateTime @default(now()) @map("fetched_at")

  @@unique([category, yearMonth, hsCode, countryCd], name: "uniq_cat_ym_hs_cnty")
  @@index([category, yearMonth])
  @@index([category, hsCode])
  @@map("trade_stats")
}

model VipHolding {
  rcpNo            String   @id @map("rcp_no")
  code             String?
  corpCode         String   @map("corp_code")
  corpName         String   @map("corp_name")
  reportNm         String   @map("report_nm")
  reportType       String   @map("report_type")
  flrNm            String   @map("flr_nm")
  rceptDt          DateTime @map("rcept_dt")
  stockRatio       Float?   @map("stock_ratio")
  stockRatioChange Float?   @map("stock_ratio_change")
  reportResn       String?  @map("report_resn")
  fetchedAt        DateTime @default(now()) @map("fetched_at")

  master           StockMaster? @relation(fields: [code], references: [code], onDelete: SetNull)

  @@index([code])
  @@index([rceptDt])
  @@map("vip_holdings")
}

model FinancialSnapshot {
  code               String   @id
  latestBsnsYear     Int      @map("latest_bsns_year")
  latestReprtCode    String   @map("latest_reprt_code")
  opIncome           BigInt?  @map("op_income")
  opIncomeYoyBase    BigInt?  @map("op_income_yoy_base")
  opIncomePrevReport BigInt?  @map("op_income_prev_report")
  opIncomeYoyPct     Float?   @map("op_income_yoy_pct")
  fetchedAt          DateTime @default(now()) @map("fetched_at")

  master  StockMaster @relation(fields: [code], references: [code], onDelete: Cascade)

  @@map("financial_snapshots")
}

model OperatingIncomeHistory {
  code       String
  bsnsYear   Int      @map("bsns_year")
  reprtCode  String   @map("reprt_code")
  thstrm     BigInt?  @map("thstrm")
  fetchedAt  DateTime @default(now()) @map("fetched_at")

  master     StockMaster @relation(fields: [code], references: [code], onDelete: Cascade)

  @@id([code, bsnsYear, reprtCode])
  @@index([code, bsnsYear])
  @@map("operating_income_history")
}

model RefreshState {
  kind        String   @id
  status      String
  startedAt   DateTime @map("started_at")
  finishedAt  DateTime? @map("finished_at")
  output      String?

  @@map("refresh_states")
}

model Tag {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  createdAt DateTime   @default(now()) @map("created_at")
  stocks    StockTag[]

  @@map("tags")
}

model StockTag {
  stockCode String   @map("stock_code")
  tagId     Int      @map("tag_id")
  createdAt DateTime @default(now()) @map("created_at")

  master    StockMaster @relation(fields: [stockCode], references: [code], onDelete: Cascade)
  tag       Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([stockCode, tagId])
  @@index([tagId])
  @@map("stock_tags")
}

model PriceChange {
  code         String    @id
  currentPrice Float?    @map("current_price")
  pastPrice    Float?    @map("past_price")
  pastDate     DateTime? @map("past_date")
  pctChange    Float?    @map("pct_change")
  marcap       BigInt?   @map("marcap")
  fetchedAt    DateTime  @default(now()) @map("fetched_at")

  master  StockMaster @relation(fields: [code], references: [code], onDelete: Cascade)

  @@map("price_changes")
}

model StockMemo {
  code      String   @id
  text      String
  updatedAt DateTime @updatedAt @map("updated_at")

  master    StockMaster @relation(fields: [code], references: [code], onDelete: Cascade)

  @@map("stock_memos")
}

model StockOverride {
  code      String   @id
  manualRoe Float?   @map("manual_roe")
  updatedAt DateTime @updatedAt @map("updated_at")

  master    StockMaster @relation(fields: [code], references: [code], onDelete: Cascade)

  @@map("stock_overrides")
}

model Disclosure {
  rcpNo      String   @id @map("rcp_no")
  code       String
  corpCode   String   @map("corp_code")
  reportNm   String   @map("report_nm")
  pblntfTy   String   @map("pblntf_ty")
  rceptDt    DateTime @map("rcept_dt")
  category   String
  payload    String?
  fetchedAt  DateTime @default(now()) @map("fetched_at")

  master     StockMaster @relation(fields: [code], references: [code], onDelete: Cascade)

  @@index([code, rceptDt])
  @@index([category])
  @@map("disclosures")
}

model StockLink {
  id        String   @id @default(uuid())
  code      String
  url       String
  title     String?
  siteName  String?  @map("site_name")
  imageUrl  String?  @map("image_url")
  kind      String   @default("blog")
  memo      String?
  createdAt DateTime @default(now()) @map("created_at")

  master    StockMaster @relation(fields: [code], references: [code], onDelete: Cascade)

  @@unique([code, url])
  @@index([code, createdAt])
  @@map("stock_links")
}

model StockRating {
  code      String   @id
  grade     String   // "high"=상 | "mid"=중 | "low"=하
  updatedAt DateTime @updatedAt @map("updated_at")

  master    StockMaster @relation(fields: [code], references: [code], onDelete: Cascade)

  @@index([grade])
  @@map("stock_ratings")
}

model EtfWatch {
  code      String   @id
  isin      String?  @map("isin")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  snapshots EtfPdfSnapshot[]

  @@map("etf_watches")
}

model EtfPdfSnapshot {
  id        String   @id @default(uuid())
  etfCode   String   @map("etf_code")
  trdDd     String   @map("trd_dd")
  fetchedAt DateTime @default(now()) @map("fetched_at")

  watch    EtfWatch        @relation(fields: [etfCode], references: [code], onDelete: Cascade)
  holdings EtfPdfHolding[]

  @@unique([etfCode, trdDd])
  @@index([etfCode, trdDd])
  @@map("etf_pdf_snapshots")
}

model EtfPdfHolding {
  id              String  @id @default(uuid())
  snapshotId      String  @map("snapshot_id")
  constituentCode String  @map("constituent_code")
  constituentName String  @map("constituent_name")
  weight          Float?
  shares          Float?
  amount          Float?

  snapshot EtfPdfSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@map("etf_pdf_holdings")
}
